{
  "manifest_version": 3,
  "name": "Cookie-Monster",
  "version": "0.1.0",
  "description": "One-click capture of session cookies to your local filesystem — for CLI tools, curl, and Claude Code.",
  "browser_specific_settings": {
    "gecko": {
      "id": "cookie-monster@cookiemonster.com",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookie-Monster",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "cookies",
    "activeTab",
    "clipboardWrite",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
